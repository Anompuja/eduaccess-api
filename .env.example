# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_PORT=8080                # local port (overridden by $PORT on Heroku/Azure)
# PORT=                      # injected automatically by Heroku / Azure Container Apps — do not set manually

# Comma-separated allowed CORS origins. Use * for local dev only.
CORS_ALLOW_ORIGINS=*

# ── Database ─────────────────────────────────────────────────────────────────
# Option A — single connection string (recommended for Supabase/cloud)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Option B — individual vars (for local Docker Postgres)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=secret
# DB_NAME=eduaccess
# DB_SSLMODE=disable

# Connection pool — keep DB_MAX_OPEN_CONNS ≤ 15 when using Supabase session-mode pooler (port 5432)
# DB_MAX_OPEN_CONNS=10
# DB_MAX_IDLE_CONNS=3

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get all values from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT validation — Dashboard → Settings → API → JWT Settings
# Used as fallback HS256 verification. Primary validation uses ECDSA JWKS from SUPABASE_URL.
SUPABASE_JWT_SECRET=

# ── Midtrans (payment gateway) ───────────────────────────────────────────────
# Use sandbox credentials during development; switch to production for live payments.
# Keys: https://dashboard.midtrans.com → Settings → Access Keys
MIDTRANS_ENVIRONMENT=sandbox            # sandbox | production
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=                    # optional — only needed if frontend uses Snap JS
MIDTRANS_PAYMENT_EXPIRY_MINUTES=1440   # 1440 = 24 hours

# ── Attendance QR ─────────────────────────────────────────────────────────────
# HMAC-SHA256 key for signing 30-second QR tokens.
# Generate with: openssl rand -hex 32
# If unset, a random key is generated per-process — tokens won't survive a server restart.
ATTENDANCE_SECRET=
# Minutes after class start_time before a scan is marked "late" (default: 15)
# LATE_TOLERANCE_MINUTES=15

# ── Swagger (production / cloud deployments) ──────────────────────────────────
# Set these when deploying to a cloud host so Swagger UI sends requests to the correct base URL.
# SWAGGER_HOST — hostname only, no protocol, no trailing slash.
# SWAGGER_SCHEME — https (recommended for any cloud deployment) or http.
SWAGGER_HOST=localhost:8080
SWAGGER_SCHEME=https
