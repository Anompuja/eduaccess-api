# Application
APP_ENV=development
APP_PORT=8080
# Comma-separated list of allowed CORS origins
CORS_ALLOW_ORIGINS=*

# Database — Supabase connection string (preferred) or individual vars for local dev
DATABASE_URL=
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=secret
# DB_NAME=eduaccess
# DB_SSLMODE=disable
# DB_MAX_OPEN_CONNS=10   # keep ≤15 when using Supabase session-mode pooler (port 5432)
# DB_MAX_IDLE_CONNS=3

# Supabase — get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret: Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# Attendance QR
# HMAC-SHA256 key for signing 30-second QR tokens. Generate with: openssl rand -hex 32
# If unset, a random key is generated per-process (tokens won't survive a server restart).
ATTENDANCE_SECRET=
# Minutes after class start_time before a QR scan is considered "late" (default: 15)
# LATE_TOLERANCE_MINUTES=15
# Midtrans - use sandbox first for development/UAS demo
MIDTRANS_ENVIRONMENT=sandbox
MIDTRANS_SERVER_KEY=
# Optional if the frontend later uses Snap JS directly on web
MIDTRANS_CLIENT_KEY=
# Checkout link expiration in minutes
MIDTRANS_PAYMENT_EXPIRY_MINUTES=1440

SWAGGER_HOST=  
