# Application
APP_ENV=development
APP_PORT=8080
# Comma-separated list of allowed CORS origins
CORS_ALLOW_ORIGINS=*

# Database — Supabase connection string (preferred) or individual vars for local dev
DATABASE_URL=
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=secret
# DB_NAME=eduaccess
# DB_SSLMODE=disable
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=5

# Supabase — get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret: Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=
