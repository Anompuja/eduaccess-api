# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_PORT=8080                # HTTP port the server listens on

# Comma-separated allowed CORS origins. Keep * for local dev.
CORS_ALLOW_ORIGINS=*

# ── Database ─────────────────────────────────────────────────────────────────
# Use the Supabase connection string from: Dashboard → Settings → Database → Connection string (URI mode)
# Use port 5432 (Session mode) — NOT 6543 (Transaction mode), GORM requires session mode.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Supabase ─────────────────────────────────────────────────────────────────
# All values from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...          # "anon public" key
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # "service_role" key — keep secret

# JWT validation — Dashboard → Settings → API → JWT Settings → JWT Secret
# Used only as fallback. Primary token validation uses ECDSA JWKS fetched from SUPABASE_URL.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Midtrans (payment gateway) ───────────────────────────────────────────────
# Keys: https://dashboard.midtrans.com → Settings → Access Keys
MIDTRANS_ENVIRONMENT=sandbox            # sandbox | production
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_PAYMENT_EXPIRY_MINUTES=1440    # 1440 = 24 hours

# ── Attendance QR ─────────────────────────────────────────────────────────────
# HMAC-SHA256 key for signing QR tokens. Generate with: openssl rand -hex 32
# If left empty a random key is generated on each restart (tokens won't survive restarts).
ATTENDANCE_SECRET=

# ── Swagger ───────────────────────────────────────────────────────────────────
# For local development keep these as-is.
# Change SWAGGER_HOST and SWAGGER_SCHEME only when deploying to a cloud host.
SWAGGER_HOST=localhost:8080
SWAGGER_SCHEME=http
